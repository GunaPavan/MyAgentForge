# ============================================================
# Pick ONE provider below. Get a key, browse their models catalog,
# then fill in LLM_API_KEY, LLM_BASE_URL, and MODEL_NAME.
# MyAgentForge works with any OpenAI-compatible API.
# ============================================================

# Option 1: Cerebras (FREE, FASTEST)
# Key: https://cloud.cerebras.ai/platform/api-keys
# Models: https://inference-docs.cerebras.ai/introduction
LLM_API_KEY=<your-key>
LLM_BASE_URL=https://api.cerebras.ai/v1
MODEL_NAME=<pick-from-models-link>

# Option 2: Groq (FREE, daily token limit)
# Key: https://console.groq.com/keys
# Models: https://console.groq.com/docs/models
# LLM_BASE_URL=https://api.groq.com/openai/v1

# Option 3: Google Gemini (FREE, 1500 req/day on 2.0 Flash)
# Key: https://aistudio.google.com/apikey
# Models: https://ai.google.dev/gemini-api/docs/models/gemini
# LLM_BASE_URL=https://generativelanguage.googleapis.com/v1beta/openai/

# Option 4: OpenRouter (FREE TIER, aggregator for many models)
# Key: https://openrouter.ai/keys
# Models: https://openrouter.ai/models
# LLM_BASE_URL=https://openrouter.ai/api/v1

# Option 5: Mistral (FREE TIER)
# Key: https://console.mistral.ai/api-keys/
# Models: https://docs.mistral.ai/getting-started/models/models_overview/
# LLM_BASE_URL=https://api.mistral.ai/v1

# Option 6: Together AI ($25 FREE CREDIT)
# Key: https://api.together.xyz/settings/api-keys
# Models: https://docs.together.ai/docs/serverless-models
# LLM_BASE_URL=https://api.together.xyz/v1

# Option 7: SambaNova (FREE TIER)
# Key: https://cloud.sambanova.ai/apis
# Models: https://docs.sambanova.ai/cloud/docs/get-started/supported-models
# LLM_BASE_URL=https://api.sambanova.ai/v1

# Option 8: DeepSeek (CHEAP, ~$0.14/1M tokens)
# Key: https://platform.deepseek.com/api_keys
# Models: https://api-docs.deepseek.com/quick_start/pricing
# LLM_BASE_URL=https://api.deepseek.com/v1

# Option 9: OpenAI (PAID)
# Key: https://platform.openai.com/api-keys
# Models: https://platform.openai.com/docs/models
# LLM_BASE_URL=https://api.openai.com/v1

# Option 10: Ollama (LOCAL, unlimited, requires Ollama installed)
# Install: https://ollama.com/download
# Models: https://ollama.com/library
# LLM_API_KEY=ollama
# LLM_BASE_URL=http://localhost:11434/v1

# ============================================================
# Execution Mode
# ============================================================
# MODE controls how much the swarm spends on LLM calls:
#   mock : zero cost. Returns canned responses. Perfect for UI/DB testing.
#   dev  : minimal real LLM calls. Tiny outputs, no review loops, skip Tester. Pennies per run.
#   prod : full quality (default). Use for real work or demos.
MODE=dev

# ============================================================
# Fine-grained knobs (override mode defaults if set)
# ============================================================
# MAX_REVIEW_ITERATIONS   0 = no fix loop, N = up to N Coder->Reviewer cycles
# SKIP_TESTER             true = skip Tester agent (saves 1 LLM call)
# COMBINE_ORCHESTRATOR    true = merge Orchestrator+Planner into one call
# MAX_TOKENS              0 = model's default. Set N to cap output length.
# LLM_TIMEOUT             Per-request timeout in seconds (default 60)
# MAX_REVIEW_ITERATIONS=1
# SKIP_TESTER=false
# COMBINE_ORCHESTRATOR=true
# MAX_TOKENS=0
# LLM_TIMEOUT=60
